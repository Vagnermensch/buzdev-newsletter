# Copy to .env for local dev:  cp .env.example .env  (then fill in)
# .env is gitignored — never commit real credentials.

# Your full Gmail address (also the authenticated From).
GMAIL_USER=you@gmail.com

# A Gmail "App password" (16 chars), NOT your normal password.
# Create at: Google Account → Security → 2-Step Verification → App passwords.
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Optional
MAIL_FROM_NAME=Newsletter
PORT=3000
RATE_MAX=5
RATE_WINDOW_SEC=60
MAX_RECIPIENTS=50
